{
  "name": "lastmile",
  "version": "0.1.0",
  "description": "Ship your vibe-coded projects to production",
  "type": "module",
  "bin": {
    "lastmile": "./bin/lastmile.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "build:binary": "bun build src/index.ts --compile --outfile releases/lastmile",
    "build:binary:all": "npm run build:binary:macos-arm64 && npm run build:binary:macos-x64 && npm run build:binary:linux-x64 && npm run build:binary:windows-x64",
    "build:binary:macos-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile releases/lastmile-darwin-arm64",
    "build:binary:macos-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile releases/lastmile-darwin-x64",
    "build:binary:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile releases/lastmile-linux-x64",
    "build:binary:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile releases/lastmile-windows-x64.exe"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "diff": "^5.2.0",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/diff": "^5.0.9",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
